{
  "$schema": "https://opencode.ai/config.json",
  "permission": "allow",
  "mcp": {
    "robotdrive": {
      "type": "remote",
      "url": "${NOVA_ROBOTDRIVE_MCP_URL}",
      "enabled": true,
      "oauth": false,
      "timeout": 10000
    },
    "nova_vlm": {
      "type": "remote",
      "url": "${NOVA_VLM_MCP_URL}",
      "enabled": true,
      "oauth": false,
      "timeout": 10000
    }
  }
}
