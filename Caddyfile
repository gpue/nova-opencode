# Caddy reverse proxy for nova-opencode
# Consolidates OpenCode web UI (4096) and MCP bridge (8081) behind
# a single port (8080) under the BASE_PATH prefix.
#
# {$BASE_PATH} is set via environment variable (default: /cell/nova-opencode)
#
# OpenCode serves all assets from "/" (root-relative). Since we serve
# behind a sub-path, we inject <base href="{BASE_PATH}/"> into the HTML
# <head> using the replace-response module so the browser resolves asset
# URLs correctly.

{
	order replace after encode
}

:8080 {
	# Health check — must come before catch-all proxy handlers.
	# The operator probes {BASE_PATH}/health, not /health.
	handle {$BASE_PATH}/health {
		respond "ok" 200
	}

	# Serve the app icon statically
	handle {$BASE_PATH}/app_icon.svg {
		root * /app/static
		rewrite * /app_icon.svg
		file_server
	}

	# MCP bridge endpoint — strip prefix, proxy to internal MCP server
	handle_path {$BASE_PATH}/mcp/* {
		reverse_proxy localhost:8081
	}
	handle_path {$BASE_PATH}/mcp {
		reverse_proxy localhost:8081
	}

	# OpenCode web UI — strip prefix, proxy to OpenCode server.
	# Inject <base href> so root-relative asset paths resolve under BASE_PATH.
	handle_path {$BASE_PATH}/* {
		reverse_proxy localhost:4096 {
			header_up Accept-Encoding identity
		}
		replace {
			"<head>" "<head><base href=\"{$BASE_PATH}/\">"
		}
	}

	# Bare path redirect (no trailing slash)
	handle {$BASE_PATH} {
		redir {$BASE_PATH}/ permanent
	}

	# Fallback health check (bare /health, no prefix)
	handle /health {
		respond "ok" 200
	}
}
